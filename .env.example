# FitArena Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (Neon Postgres or local)
DATABASE_URL=postgres://fitarena:fitarena_dev_password@localhost:5432/fitarena

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Strava API
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/v1/integrations/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=fitarena_strava_webhook

# Google Fit API
GOOGLE_FIT_CLIENT_ID=your_google_client_id
GOOGLE_FIT_CLIENT_SECRET=your_google_client_secret
GOOGLE_FIT_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-fit/callback

# WhatsApp Business API (Interakt/AiSensy)
WHATSAPP_API_URL=https://api.interakt.ai/v1
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_BUSINESS_NUMBER=your_whatsapp_number

# Anthropic Claude API (for AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Mapbox
MAPBOX_ACCESS_TOKEN=your_mapbox_token
MAPBOX_DOWNLOAD_TOKEN=your_mapbox_download_token

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Razorpay (for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS Provider (MSG91 or Twilio)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=FITARN

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:8081

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn
