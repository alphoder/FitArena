{
  "name": "fitarena",
  "version": "0.1.0",
  "private": true,
  "description": "Competitive fitness platform with territory control",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @fitarena/db generate",
    "db:migrate": "pnpm --filter @fitarena/db migrate",
    "db:push": "pnpm --filter @fitarena/db push",
    "db:studio": "pnpm --filter @fitarena/db studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
